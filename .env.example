# Auth mode: auto | api | cookies
# auto = uses X_BEARER_TOKEN if present, otherwise COOKIE_FILE
AUTH_MODE=auto

# API mode
X_BEARER_TOKEN=replace_with_your_token

# Cookie mode (Playwright storage state JSON, cookies JSON array, or Netscape cookies.txt)
COOKIE_FILE=x_storage_state.json
HEADLESS=true
SEARCH_SCROLLS=3
SEARCH_WAIT_MS=1800

# Browser engine for cookie mode: playwright | cloak
# If cloak: run `pip install cloakbrowser`
BROWSER_ENGINE=playwright
CLOAK_HUMANIZE=true

# Optional tuning
RUN_EVERY_MINUTES=60
MAX_RESULTS=50
LANGUAGE_FILTER=en
STATE_FILE=state.json
OUTPUT_FILE=alerts.jsonl

# Extra X search operators (applied to the right of the focus+promo query)
EXTRA_QUERY=(has:media OR has:video OR has:links)

# Comma-separated term lists (no quoting needed — simply separate with commas)
# Terms with spaces like "Claude Code" work fine without quotes
FOCUS_TERMS=Claude Code,Claude Max,Codex CLI,GPT-5,GPT-5 Pro,ChatGPT Plus,GLM-5,Qwen Plus,Qwen Max,Kimi Explorer,Hermes Agent,OpenClaw,Midjourney,Copilot Pro,Cursor
PROMO_TERMS=promo code,discount code,coupon code,% off,limited time offer,sale,deal on,deal for,subscription,plan,free trial,extended trial,early access,early bird,beta invite,beta access,subscribe now,subscribe today,upgrade to,price drop,special offer,starting at $
EXCLUDE_TERMS=layoff,severance,shareholder,earnings call,fda approved,fda clearance,ipo,going public,gcse,sag-aftra
BLOCKLIST_USERNAMES=news,breaking,daily,alerts,digest,watch,tracker,updates,wire,press,reuters,apnews

# Optional Telegram alerts
# TELEGRAM_BOT_TOKEN=123456789:ABCDEF...
# TELEGRAM_CHAT_ID=123456789
